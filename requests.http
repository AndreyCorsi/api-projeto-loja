# =========================
# CLIENTES
# =========================

### Criar cliente
POST http://localhost:3000/clientes
Content-Type: application/json

{
  "nome": "Maria Silva",
  "cpf": "12345678901",
  "email": "maria@email.com",
  "senha": "1234",
  "telefone": "11999999999",
  "rua": "Rua A",
  "num": 10,
  "cidade": "SP",
  "data_nasc": "2000-01-01",
  "id_categoria_cliente": 1
}
###

### Listar clientes
GET http://localhost:3000/clientes

###

### Buscar cliente por id
GET http://localhost:3000/clientes/1

###

### Atualizar cliente
PUT http://localhost:3000/clientes/1
Content-Type: application/json

{
  "nome": "Maria Silva Atualizada",
  "cpf": "12345678901",
  "email": "maria.atualizada@email.com",
  "senha": "1234",
  "telefone": "11988888888",
  "endereco": "Rua B, 20 - Centro - SP",
  "data_nasc": "2000-01-01",
  "id_categoria": 1
}

###

### Excluir cliente
DELETE http://localhost:3000/clientes/1

###

# =========================
# PRODUTOS
# =========================

### Criar produto
POST http://localhost:3000/produtos
Content-Type: application/json

{
  "nome": "Tenis Azul",
  "descricao": "Tenis casual azul",
  "tamanho": "42",
  "cor": "Azul",
  "marca": "Nike",
  "codigo_barras": "7891234567890",
  "estoque": 10,
  "estoque_min": 2,
  "custo": 250,
  "venda": 400,
  "promocional": 350,
  "margem": 150,
  "id_fornecedor": 1,
  "id_categoria_roupa": 1,
  "status": "ativo"
}

###

### Listar produtos
GET http://localhost:3000/produtos

###

### Buscar produto por id
GET http://localhost:3000/produtos/2

###

### Atualizar produto
PUT http://localhost:3000/produtos/1
Content-Type: application/json

{
  "nome": "Tenis Azul Atualizado",
  "preco": 420,
  "descricao": "Tenis casual azul atualizado",
  "tamanho": "42",
  "cor": "Azul",
  "marca": "Nike",
  "codigo_barras": "7891234567890",
  "estoque": 15,
  "custo": 260,
  "venda": 420,
  "margem": 160,
  "promocional": 380,
  "id_fornecedor": 1,
  "id_categoria_roupa": 1,
  "status": "ATIVO"
}

###

### Excluir produto
DELETE http://localhost:3000/produtos/1

###

