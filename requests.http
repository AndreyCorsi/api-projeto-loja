# =========================
# FAQ
# =========================

### Criar FAQ
POST http://localhost:3000/faq
Content-Type: application/json

{
  "pergunta": "Qual o prazo de entrega?",
  "ordem": 1,
  "resposta": "O prazo de entrega varia de 3 a 7 dias úteis."
}

###

### Listar FAQ
GET http://localhost:3000/faq

###

### Atualizar FAQ
PUT http://localhost:3000/faq/1
Content-Type: application/json

{
  "pergunta": "Qual e o prazo de entrega?",
  "ordem": 1,
  "resposta": "O prazo de entrega varia de 2 a 5 dias úteis."
}

###

### Excluir FAQ
DELETE http://localhost:3000/faq/1

###

# =========================
# PEDIDOS
# =========================

### Criar pedido com itens
POST http://localhost:3000/pedidos
Content-Type: application/json

{
  "pedido": {
    "data_hora": "2026-04-07T20:00:00.000Z",
    "subtotal": 800,
    "valor_total": 800,
    "forma_pagto": "PIX",
    "status": "PENDENTE",
    "id_cliente": 1
  },
  "itens": [
    {
      "id_produto": 1,
      "qtd": 1
    },
    {
      "id_produto": 2,
      "qtd": 2
    }
  ]
}

###

### Listar pedidos
GET http://localhost:3000/pedidos

###

# =========================
# MOVIMENTACOES DE ESTOQUE
# =========================

### Listar movimentacoes
GET http://localhost:3000/movimentacoes

###

### Buscar movimentacoes por produto
GET http://localhost:3000/movimentacoes/produto/1

###

### Registrar entrada de estoque
POST http://localhost:3000/estoque/entrada
Content-Type: application/json

{
  "qtd": 5,
  "id_produto": 1,
  "id_funcionario": 1,
  "id_pedido": null
}

###

### Registrar saida de estoque
POST http://localhost:3000/estoque/saida
Content-Type: application/json

{
  "qtd": 2,
  "id_produto": 1,
  "id_funcionario": 1,
  "id_pedido": 1
}

###

